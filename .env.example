# Required: Google AI Studio key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Optional but strongly recommended (higher GitHub API rate limits)
GITHUB_TOKEN=

# Optional: override default Gemini model
GEMINI_MODEL=gemini-2.0-flash

# Optional: PEM bundle for TLS (corporate proxy). On Windows, prefer system store:
# SSL_USE_SYSTEM_STORE=1
# SSL_CERT_FILE=C:\path\to\corp-root.pem
